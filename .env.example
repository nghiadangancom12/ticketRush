# =========================================
# TicketRush Environment Variables
# =========================================

# 🌐 Frontend URL (Important for CORS)
FRONTEND_URL=http://localhost:5173

# 🔙 Backend URL
BACKEND_URL=http://localhost:3000

# 🔑 JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_COOKIE_EXPIRES_IN=1

# 📊 Environment
NODE_ENV=development

# 🗄️ Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ticketrush

# 📧 Email Configuration (Optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# 💳 Payment Gateway (Optional)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# 🔐 Encryption Keys (Optional)
ENCRYPTION_KEY=your-encryption-key

# =========================================
# Production Setup
# =========================================

# Uncomment và sửa khi chạy production:
# FRONTEND_URL=https://app.ticketrush.com
# BACKEND_URL=https://api.ticketrush.com
# NODE_ENV=production
# JWT_COOKIE_EXPIRES_IN=7
