generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model events {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String             @db.VarChar(255)
  description String?
  image_url   String?            @db.VarChar(500)
  start_time  DateTime           @db.Timestamptz(6)
  location    String             @db.VarChar(255)
  status      event_status_enum? @default(DRAFT)
  created_at  DateTime?          @default(now()) @db.Timestamptz(6)
  admin_id    String?            @db.Uuid
  users       users?             @relation(fields: [admin_id], references: [id], onUpdate: NoAction)
  zones       zones[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String             @db.Uuid
  total_amount Decimal            @db.Decimal(12, 2)
  status       order_status_enum? @default(PENDING)
  created_at   DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?          @default(now()) @db.Timestamptz(6)
  users        users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tickets      tickets[]

  @@index([user_id], map: "idx_orders_user")
}

model seats {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zone_id     String            @db.Uuid
  row_label   String            @db.VarChar(10)
  seat_number Int
  status      seat_status_enum? @default(AVAILABLE)
  locked_by   String?           @db.Uuid
  locked_at   DateTime?         @db.Timestamptz(6)
  users       users?            @relation(fields: [locked_by], references: [id], onUpdate: NoAction)
  zones       zones             @relation(fields: [zone_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tickets     tickets?

  @@unique([zone_id, row_label, seat_number])
  @@index([status, locked_at], map: "idx_seats_locked_status")
  @@index([zone_id, row_label, seat_number], map: "idx_seats_matrix")
  @@index([zone_id, status], map: "idx_seats_zone_status")
}

model tickets {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id  String    @db.Uuid
  seat_id   String    @unique @db.Uuid
  qr_code   String    @unique @db.VarChar(255)
  issued_at DateTime? @default(now()) @db.Timestamptz(6)
  orders    orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  seats     seats     @relation(fields: [seat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String       @unique @db.VarChar(255)
  password      String       @db.VarChar(255)
  full_name     String       @db.VarChar(255)
  date_of_birth DateTime?    @db.Date
  gender        gender_enum?
  avatar_url    String?      @db.VarChar(500)
  role          role_enum?   @default(CUSTOMER)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  events        events[]
  orders        orders[]
  seats         seats[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model zones {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id    String    @db.Uuid
  name        String    @db.VarChar(100)
  price       Decimal   @db.Decimal(12, 2)
  total_seats Int
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  seats       seats[]
  events      events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum event_status_enum {
  DRAFT
  PUBLISHED
  CLOSED
}

enum gender_enum {
  MALE
  FEMALE
  OTHER
}

enum order_status_enum {
  PENDING
  PAID
  CANCELLED
}

enum role_enum {
  ADMIN
  CUSTOMER
}

enum seat_status_enum {
  AVAILABLE
  LOCKED
  SOLD
}
